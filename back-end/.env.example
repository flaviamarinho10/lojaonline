# =============================================
# BANCO DE DADOS - Supabase PostgreSQL
# =============================================
# Encontre em: Supabase Dashboard > Settings > Database > Connection string > URI
# Use a connection string com Transaction pooler (porta 6543) para produção
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# =============================================
# SUPABASE - API e Storage
# =============================================
# Encontre em: Supabase Dashboard > Settings > API
SUPABASE_URL="https://[project-ref].supabase.co"

# Use a Service Role Key (nunca exponha no front-end!)
SUPABASE_SERVICE_KEY="eyJ..."

# =============================================
# AUTENTICAÇÃO
# =============================================
JWT_SECRET="sua-chave-jwt-secreta-aqui"

# =============================================
# SERVIDOR
# =============================================
PORT=3333
FRONTEND_URL="http://localhost:5173"
